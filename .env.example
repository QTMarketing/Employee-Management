AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=gravity-employee-documents

# Auth
ADMIN_EMAIL=admin@gravity.local
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin User
AUTH_SECRET=change-this-secret-in-production

# Supabase (required for Vercel-compatible API routes)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

# Optional: enable legacy local Express proxy in development
# USE_EXPRESS_PROXY=true
